# Gradle / Kotlin
.gradle/
build/
**/build/
.kotlin/
local.properties
captures/

# IntelliJ / Android Studio
.idea/
*.iml
*.ipr
*.iws

# Android
*.apk
*.aab
*.ap_
*.dex
# Release build artifacts live under build/ (already ignored above). Do NOT use a bare `release/`
# pattern here — it would also swallow non-build dirs like docs/release/.

# iOS / Xcode / KMP
*.xcuserstate
*.xcworkspace/xcuserdata/
xcuserdata/
DerivedData/
**/iosApp/Pods/
**/iosApp/*.xcworkspace
Podfile.lock

# Kotlin/Native
*.klib

# macOS
.DS_Store

# Secrets / signing / per-account config (ADS-0, Sprint 8) — NEVER commit these.
# The spike uses only Google's PUBLIC AdMob test IDs (safe to commit); the REAL AdMob App ID /
# ad-unit IDs and any signing material are injected at release from these gitignored files.
secrets.properties
google-services.json
GoogleService-Info.plist
*.keystore
*.jks
# Android release signing material (REL): the upload keystore + the properties file that
# points at it and holds its passwords. Only keystore.properties.template is committed.
keystore.properties

# Misc
*.log
.env
